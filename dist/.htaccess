# dist request routing (.htaccess)

# alle requests, die keine bilddateien sind, an app.php weiterleiten.
# bildendungen werden direkt ausgeliefert.

RewriteEngine On

# API requests always go through api.php
RewriteRule ^api(?:/(.*))?$ api.php?__path=$1 [L,QSA,NC]

RewriteCond %{REQUEST_URI} \.(png|jpg|jpeg|gif|webp|svg|ico)$ [NC]
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ app.php [L,QSA]
