# Dist request routing (.htxss)

# Alle Requests, die keine Bilddateien sind, an Execute.php weiterleiten.
# Bildendungen werden direkt ausgeliefert.

RewriteEngine On

RewriteCond %{REQUEST_URI} \.(png|jpg|jpeg|gif|webp|svg|ico)$ [NC]
RewriteRule ^ - [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ Execute.php [L,QSA]
